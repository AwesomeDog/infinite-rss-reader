{
  "description": "Infinite RSS Reader for Thunderbird",
  "manifest_version": 2,
  "name": "Infinite RSS Reader",
  "version": "0.0.0",
  "icons": {
    "48": "icons/rss.svg"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "infrss@awesomedog.github.io",
      "strict_min_version": "91.0"
    }
  },

  "background": {
    "scripts": ["background.js"]
  },

  "browser_action": {
    "default_icon": "icons/rss.svg"
  },

  "permissions": [
    "nativeMessaging",
    "accountsRead",
    "messagesRead",
    "messagesUpdate"
  ]
}
